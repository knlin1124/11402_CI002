int main() {
    int fib[50];

    fib[0] = 1;
    fib[1] = 2;

    int cnt = 2;

    while (true) {
        fib[cnt] = fib[cnt - 1] + fib[cnt - 2];

        if (fib[cnt] > 100000000)
            break;

        cnt++;
    }

    int T;
    cin >> T;

    while (T--) {
        int n;
        cin >> n;

        int original = n;
        string ans = "";

        bool start = false;

        for (int i = cnt; i >= 0; i--) {
            if (fib[i] <= n) {
                ans += '1';
                n -= fib[i];
                start = true;
            }
            else if (start) {
                ans += '0';
            }
        }

        cout << original << " = " << ans << " (fib)" << endl;
    }

    return 0;
}
